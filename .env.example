# Sound Forge Alchemy - Environment Variables
# Copy to .env and fill in your values

# === Required for Production ===

# Database connection string
DATABASE_URL=ecto://USER:PASS@HOST/sound_forge_prod

# Secret key base (generate with: mix phx.gen.secret)
SECRET_KEY_BASE=

# Public hostname for your deployment
PHX_HOST=example.com

# === Optional ===

# Server port (default: 4000)
PORT=4000

# Enable server in release mode
PHX_SERVER=true

# Database pool size (default: 10)
POOL_SIZE=10

# Enable IPv6 for database connection
# ECTO_IPV6=true

# DNS cluster query for distributed deployments
# DNS_CLUSTER_QUERY=

# === Spotify API (required for metadata fetching) ===

# Get from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Aliases for spotipy/spotdl CLI (expects SPOTIPY_ prefix)
# Set these to the same values as SPOTIFY_CLIENT_ID/SECRET above
SPOTIPY_CLIENT_ID=
SPOTIPY_CLIENT_SECRET=

# === lalal.ai Cloud Stem Separation ===

# Global API key for all users (optional)
LALALAI_API_KEY=

# System activation key - automatically granted to pro/enterprise/admin users in seeds
# Get from your lalal.ai account or enterprise dashboard
SYSTEM_LALALAI_ACTIVATION_KEY=

# === Worker Mode (Azure multi-container deployment) ===

# Controls which Oban queues and supervision tree components are started
# "full"       - All queues + web endpoint + MIDI (default, local dev)
# "web"        - download + analysis queues, web endpoint (no GPU processing)
# "gpu_worker" - processing queue only (no web endpoint, no MIDI)
# WORKER_MODE=full

# Override storage path (default: priv/uploads)
# STORAGE_PATH=/app/priv/uploads

# Override Python executable path (default: auto-detect via PATH)
# DEMUCS_PYTHON=/opt/venv/bin/python3

# === Encryption ===

# Base64-encoded 32-byte key for LLM provider API key encryption (Cloak vault)
# Generate with: :crypto.strong_rand_bytes(32) |> Base.encode64()
# If unset, derives key from SECRET_KEY_BASE via SHA-256
# IMPORTANT: Use a unique key per environment (dev/qa/staging/prod)
# LLM_ENCRYPTION_KEY=

# === LLM Provider API Keys ===

# Anthropic (Claude)
# ANTHROPIC_API_KEY=

# OpenAI
# OPENAI_API_KEY=

# Azure OpenAI
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=

# Google AI (Gemini)
# GOOGLE_AI_API_KEY=

# === Python Dependencies ===
# The following Python packages are required for audio processing:
#   pip install demucs librosa soundfile numpy
# spotdl is required for Spotify downloads:
#   pip install spotdl
# Or use: pip install -r priv/python/requirements.txt
